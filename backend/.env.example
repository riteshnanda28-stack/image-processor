# Server Configuration
PORT=5000

# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://username:password@cluster0.mongodb.net/image-processor?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Redis/Bull Queue Configuration (Upstash)
REDIS_HOST=your-upstash-redis-host.upstash.io
REDIS_PORT=6379
REDIS_PASSWORD=your_upstash_redis_password

# Node Environment
NODE_ENV=development
